# Hygieneschulung KjG -- Beispielkonfiguration.
# Kopiere zu `.env` und ersetze die Platzhalter.
#
# WICHTIG (Docker Compose Gotcha):
#   Docker Compose interpretiert "$" in .env-Werten als Variablen-Referenz.
#   bcrypt-Hashes beginnen mit "$2a$12$..." -- daher jedes "$" als "$$" doppeln,
#   wenn der Wert via .env an Compose uebergeben wird.
#   Beispiel-Hash echt:  $2a$12$abcdefg...
#   In .env eintragen:   $$2a$$12$$abcdefg...
#
#   Bei lokalem Setup (npm run start, ohne Docker) muss NICHT escaped werden.

# HTTP-Port (Express servt sowohl Frontend-Statics als auch /api).
PORT=3000

# Signierschluessel fuer das Admin-Cookie. Mindestens 32 zufaellige Bytes.
# Erzeugen:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
COOKIE_SECRET=BITTE_HIER_32_ZUFAELLIGE_ZEICHEN_EINSETZEN

# bcrypt-Hash des Admin-Passworts (NIE Klartext einchecken).
# Erzeugen:  node -e "console.log(require('bcryptjs').hashSync('DEIN_PASSWORT', 12))"
# In .env: jedes '$' im Hash als '$$' doppeln, wenn via docker-compose verwendet.
ADMIN_PASSWORD_HASH=BITTE_BCRYPT_HASH_HIER_EINSETZEN_FUER_DOCKER_MIT_GEDOPPELTEM_DOLLAR

# Optional: Pfad zur SQLite-Datei (Default backend/data/app.sqlite).
# DB_PATH=./data/app.sqlite
